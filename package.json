{
  "name": "broks",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run server:dev\" \"npm run dev:web\"",
    "dev:web": "next dev",
    "build": "next build",
    "start": "./scripts/start-server.sh",
    "start:force": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true && next start",
    "kill:port": "lsof -ti:3000 | xargs kill -9 2>/dev/null || true",
    "serve": "npm run kill:port && npm start",
    "lint": "next lint",
    "server:dev": "npm --prefix server run dev",
    "server:seed": "npm --prefix server run seed",
    "dev:full": "npm run dev",
    "postbuild": "next-sitemap",
    "postinstall": "npm --prefix server install"
  },
  "dependencies": {
    "@pbe/react-yandex-maps": "^1.2.5",
    "@tanstack/react-query": "^5.90.9",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.28",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.477.0",
    "next": "14.2.33",
    "next-sitemap": "^4.2.3",
    "next-themes": "^0.3.0",
    "openai": "^6.9.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-leaflet": "^4.2.1",
    "react-router-dom": "^7.9.6",
    "sharp": "^0.34.5",
    "supercluster": "^8.0.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@types/leaflet": "^1.9.11",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.4",
    "@types/react-dom": "^18.3.0",
    "@types/react-router-dom": "^5.3.3",
    "@types/supercluster": "^7.1.3",
    "autoprefixer": "^10.4.22",
    "concurrently": "^8.2.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.4.5"
  }
}
